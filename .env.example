# 访问密码（设置后启用登录保护，留空则不启用）
# 推荐使用哈希（可用 `npm run hash-password -w backend` 生成）
AUTH_PASSWORD_HASH=
# 或使用明文（仅建议局域网使用，公网请使用哈希）
AUTH_PASSWORD=

# AI 配置（可在前端设置页面覆盖，留空表示部署时不预设）
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4o-mini

# Docker Compose 对外暴露端口
MEDKIT_PORT=3000

# 源码直跑 / 非 Docker 启动端口
PORT=3000

# 代理（按需填写；访问 Telegram / Discord 等外部服务时使用）
# HTTP_PROXY=http://192.168.31.1:7890
# HTTPS_PROXY=http://192.168.31.1:7890
# NO_PROXY=localhost,127.0.0.1,.local
